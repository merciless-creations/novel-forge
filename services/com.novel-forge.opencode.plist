<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.novel-forge.opencode</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>exec "$HOME/.opencode/bin/opencode" web --port 4096</string>
    </array>

    <key>WorkingDirectory</key>
    <string>~/novels</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>~</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>~/Library/Logs/novel-forge-opencode.log</string>

    <key>StandardErrorPath</key>
    <string>~/Library/Logs/novel-forge-opencode.log</string>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
