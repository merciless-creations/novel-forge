<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.novel-forge.watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__HOME__/.local/bin/novel-forge-watcher</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>NF_DROPZONE</key>
        <string>__HOME__/DropZone</string>
        <key>NF_NOVELS_DIR</key>
        <string>__HOME__/novels</string>
        <key>NF_OPENCODE_PORT</key>
        <string>4096</string>
        <key>PATH</key>
        <string>__HOME__/.opencode/bin:__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/novel-forge-watcher.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/novel-forge-watcher.log</string>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
