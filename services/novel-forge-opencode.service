[Unit]
Description=Novel Forge — OpenCode Web Server
Documentation=https://github.com/merciless-creations/novel-forge
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
WorkingDirectory=%h/novels
ExecStart=%h/.opencode/bin/opencode web --port 4096
Restart=on-failure
RestartSec=10
Environment=HOME=%h
Environment=PATH=%h/.opencode/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin

# Load API keys from env file (generated by setup.sh)
EnvironmentFile=-%h/.config/novel-forge/env

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=novel-forge-opencode

[Install]
WantedBy=default.target
